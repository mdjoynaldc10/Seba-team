{
  "entities": {
    "publicDonors": {
      "title": "Public Donors",
      "description": "Members who have enabled blood donation publicly",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Member ID" },
        "name": { "type": "string", "description": "Member Name" },
        "group": { "type": "string", "description": "Blood Group" },
        "district": { "type": "string", "description": "Area/District" },
        "phone": { "type": "string", "description": "Phone Number" },
        "enabled": { "type": "boolean", "description": "Whether donation is enabled" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["id", "name", "group", "district", "phone", "enabled"]
    },
    "tictactoe_games": {
      "title": "TicTacToe Game",
      "description": "State of a TicTacToe game",
      "type": "object",
      "properties": {
        "board": { "type": "array", "items": { "type": ["string", "null"] } },
        "isXNext": { "type": "boolean" },
        "winner": { "type": ["string", "null"] },
        "winningLine": { "type": ["array", "null"], "items": { "type": "number" } },
        "player1Id": { "type": "string" },
        "player2Id": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["board", "isXNext", "player1Id", "player2Id"]
    },
    "post_reactions": {
      "title": "Post Reaction",
      "description": "Love reaction on a homepage post",
      "type": "object",
      "properties": {
        "postId": { "type": "string", "description": "Encoded post ID" },
        "userId": { "type": "string", "description": "User ID who reacted" },
        "userName": { "type": "string", "description": "User Name who reacted" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Reaction timestamp" }
      },
      "required": ["postId", "userId", "userName"]
    },
    "bloodDonors": {
      "title": "Blood Donor",
      "description": "Donor registration details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "group": { "type": "string" },
        "district": { "type": "string" },
        "thana": { "type": "string" },
        "phone": { "type": "string" },
        "uid": { "type": "string" },
        "isVisible": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "group", "district", "phone", "uid", "isVisible"]
    },
    "users": {
      "title": "User Profile",
      "description": "User account details",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "isGoogleUser": { "type": "boolean" },
        "phone": { "type": "string" },
        "area": { "type": "string" },
        "bloodGroup": { "type": "string" },
        "dob": { "type": "string" }
      },
      "required": ["uid"]
    },
    "settings": {
      "title": "Global Settings",
      "description": "Global application settings and customization",
      "type": "object",
      "properties": {
        "advanceSettings": { "type": "object", "description": "Global advance settings object" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["advanceSettings"]
    },
    "cloud_pins": {
      "title": "Cloud PIN",
      "description": "User security PIN settings",
      "type": "object",
      "properties": {
        "pin": { "type": "string", "description": "4+ digit PIN code" },
        "isEnabled": { "type": "boolean", "description": "Whether PIN is active" }
      },
      "required": ["pin", "isEnabled"]
    },
    "bookRequests": {
      "title": "Book Request",
      "description": "Request to borrow a book",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "bookId": { "type": "string" },
        "bookName": { "type": "string" },
        "bookAuthor": { "type": "string" },
        "requesterId": { "type": "string" },
        "requesterName": { "type": "string" },
        "requesterAddress": { "type": "string" },
        "requestDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "returned"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "approvedBy": { "type": "string" },
        "approvedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "bookId", "bookName", "requesterId", "requesterName", "status"]
    },
    "bookReviews": {
      "title": "Book Review",
      "description": "User review for a book",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "bookId": { "type": "string" },
        "reviewerId": { "type": "string" },
        "reviewerName": { "type": "string" },
        "reviewText": { "type": "string" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "bookId", "reviewerId", "reviewText", "rating"]
    },
    "notifications": {
      "title": "Notification",
      "description": "Real-time notification for a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "Target user ID" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["book_request", "request_approved", "request_rejected"] },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "message", "type", "isRead", "createdAt"]
    },
    "admin_database_links": {
      "title": "Admin Database Link",
      "description": "Custom database link for an admin",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID for the link" },
        "userId": { "type": "string", "description": "Owner of the link" },
        "name": { "type": "string", "description": "Display name of the link" },
        "sheetId": { "type": "string", "description": "Google Sheet ID" },
        "description": { "type": "string", "description": "Brief description" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "name", "sheetId"]
    },
    "global_notices": {
      "title": "Global Notice",
      "description": "Notice displayed to all logged-in users on app startup",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "message", "authorId", "authorName", "createdAt"]
    }
  },
  "firestore": {
    "/settings/{settingId}": {
      "schema": "settings",
      "description": "Global settings document"
    },
    "/cloud_pins/{userId}": {
      "schema": "cloud_pins",
      "description": "User security PIN settings"
    },
    "/publicDonors/{donorId}": {
      "schema": "publicDonors",
      "description": "Collection of members who opted-in for public blood donation"
    },
    "/bloodDonors/{donorId}": {
      "schema": "bloodDonors",
      "description": "New collection for blood donor registration"
    },
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile information"
    },
    "/tictactoe_games/{gameId}": {
      "schema": "tictactoe_games",
      "description": "Real-time TicTacToe games between members"
    },
    "/post_reactions/{reactionId}": {
      "schema": "post_reactions",
      "description": "Collection of reactions on homepage posts"
    },
    "/bookRequests/{requestId}": {
      "schema": "bookRequests",
      "description": "Collection of book borrow requests"
    },
    "/bookReviews/{reviewId}": {
      "schema": "bookReviews",
      "description": "Collection of book reviews"
    },
    "/notifications/{notificationId}": {
      "schema": "notifications",
      "description": "Collection of real-time notifications for users"
    },
    "/admin_database_links/{linkId}": {
      "schema": "admin_database_links",
      "description": "Custom database links managed by admins"
    },
    "/global_notices/{noticeId}": {
      "schema": "global_notices",
      "description": "Collection of global notices displayed to all users"
    }
  }
}
