rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Public Donors Collection
    match /publicDonors/{donorId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Blood Donors Collection
    match /bloodDonors/{donorId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // TicTacToe Games Collection
    match /tictactoe_games/{gameId} {
      allow read, write: if isAuthenticated();
    }

    // Post Reactions Collection
    match /post_reactions/{reactionId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && reactionId.endsWith("_" + resource.data.userId);
    }

    // Global Settings Collection
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAuthenticated(); // Simplified for now, can be hardened if needed
    }

    // Cloud PINs Collection
    match /cloud_pins/{userId} {
      allow read, write: if isAuthenticated();
    }

    // PIN Reset Requests Collection
    match /pin_reset_requests/{requestId} {
      allow create: if true; // Allow anyone to request a reset
      allow read: if true;   // Allow user to check their request status
      allow update: if isAuthenticated(); // Only admins/authenticated users can approve/decline
    }

    // Book Requests Collection
    match /bookRequests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated(); // Admins/Devs can update/delete, users can delete their own requests
    }

    // Book Reviews Collection
    match /bookReviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (resource.data.reviewerId == request.auth.uid);
    }

    // Notifications Collection
    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    // Admin Database Links Collection
    match /admin_database_links/{linkId} {
      allow read, write: if isAuthenticated();
    }

    // Global Notices Collection
    match /global_notices/{noticeId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // Admins can manage notices
    }

    // Sessions Collection
    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }
  }
}
