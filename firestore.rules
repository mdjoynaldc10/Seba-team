rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Public Donors Validation
    function isValidDonor(data) {
      return data.keys().hasAll(['id', 'name', 'group', 'district', 'phone', 'enabled']) &&
             data.id is string && data.id.size() > 0 &&
             data.name is string && data.name.size() > 0 &&
             data.group is string && data.group.size() > 0 &&
             data.district is string && data.district.size() > 0 &&
             data.phone is string && data.phone.size() > 0 &&
             data.enabled is bool;
    }

    // Public Donors Collection
    match /publicDonors/{donorId} {
      allow read: if true;
      allow create, update: if isAuthenticated() && isValidDonor(request.resource.data);
      allow delete: if isAuthenticated();
    }

    // TicTacToe Games Collection
    match /tictactoe_games/{gameId} {
      allow read, write: if isAuthenticated();
    }

    // Post Reactions Collection
    match /post_reactions/{reactionId} {
      // Allow everyone to read reactions to see counts
      allow read: if true;
      
      // Allow authenticated users to create reactions
      // We check that they are authenticated and providing the required fields
      allow create: if isAuthenticated() 
        && request.resource.data.keys().hasAll(['postId', 'userId', 'userName', 'createdAt']);
      
      // Allow authenticated users to delete reactions
      // We trust the client logic for now, or we can add a check that the reactionId ends with their userId
      allow delete: if isAuthenticated() && reactionId.endsWith("_" + resource.data.userId);
    }
  }
}
