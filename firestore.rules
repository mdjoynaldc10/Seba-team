rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Public Donors Collection
    match /publicDonors/{donorId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Blood Donors Collection
    match /bloodDonors/{donorId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // TicTacToe Games Collection
    match /tictactoe_games/{gameId} {
      allow read, write: if isAuthenticated();
    }

    // Post Reactions Collection
    match /post_reactions/{reactionId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && reactionId.endsWith("_" + resource.data.userId);
    }

    // Global Settings Collection
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAuthenticated(); // Simplified for now, can be hardened if needed
    }
  }
}
