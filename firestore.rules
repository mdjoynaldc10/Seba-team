rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "mdjoynaldc10@gmail.com" && request.auth.token.email_verified == true));
    }

    function isDeveloper() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'developer');
    }

    // Public Donors Collection
    match /publicDonors/{donorId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Blood Donors Collection
    match /bloodDonors/{donorId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    // TicTacToe Games Collection
    match /tictactoe_games/{gameId} {
      allow read, write: if isAuthenticated();
    }

    // Post Reactions Collection
    match /post_reactions/{reactionId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && reactionId.endsWith("_" + resource.data.userId);
    }

    // Global Settings Collection
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() || isDeveloper();
    }

    // Cloud PINs Collection
    match /cloud_pins/{userId} {
      allow read, write: if isOwner(userId);
    }

    // PIN Reset Requests Collection
    match /pin_reset_requests/{requestId} {
      allow create: if true; // Allow anyone to request a reset
      allow read: if true;   // Allow user to check their request status
      allow update: if isAdmin() || isDeveloper();
    }

    // Borrow Requests Collection
    match /borrow_requests/{requestId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
